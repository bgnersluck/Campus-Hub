{
  "manifest_version": 3,
  "name": "대학서랍",
  "version": "1.0",
  "description": "대학생들을 위한 대외활동, 공모전, 취업 정보 사이트를 한 곳에 모았습니다.😃",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
